# Copy to .env. Never commit a populated .env.

# Backend HTTP/WS port
SERVER_PORT=4000

# Frontend dev port (Vite)
CLIENT_PORT=5173

# Where user projects live on the host (absolute or repo-relative)
PROJECTS_ROOT=./projects

# Where session/project metadata lives
DATA_ROOT=./data

# Docker image tag for the agent container
AGENT_IMAGE=rca-agent:latest

# Optional: set these when the Docker daemon sees the repo/projects at a
# different absolute path than the backend process. Usually auto-detected for
# local hosts, Docker Desktop, and common Linux dev-container layouts.
DOCKER_HOST_WORKSPACE_ROOT=
DOCKER_HOST_PROJECTS_ROOT=

# Host port range for ttyd sessions (one port per active session)
TTYD_PORT_MIN=7700
TTYD_PORT_MAX=7800

# Set only when the server itself runs inside a container (e.g. docker compose).
# RCA_TTYD_PROXY_HOST: host the server uses to reach agent ttyd ports.
#   default 127.0.0.1; set to host.docker.internal in DooD.
# RCA_AGENT_BIND_HOST: interface agent containers publish their ttyd port on.
#   default 127.0.0.1; set to 0.0.0.0 in DooD so the publish is reachable
#   from the docker bridge gateway.
# RCA_TTYD_PROXY_HOST=
# RCA_AGENT_BIND_HOST=

# Docker Compose only — absolute HOST paths used by the docker daemon for the
# bind mounts the server requests for agent containers. Auto-detect handles
# most cases (Linux native, Docker Desktop on macOS) but Docker Desktop on
# Windows drops the drive-letter prefix in /proc/self/mountinfo, so set these
# explicitly there. The compose file reads them as ${HOST_REPO_DIR} /
# ${HOST_PROJECTS_DIR} and forwards them to the server as
# DOCKER_HOST_WORKSPACE_ROOT / DOCKER_HOST_PROJECTS_ROOT.
# HOST_REPO_DIR=
# HOST_PROJECTS_DIR=

# Agent credentials. Only the key matching the chosen agent kind is
# forwarded into the container environment; nothing else leaks.
#
# Claude (pick ONE of the two options below):
#   Option A — Direct Anthropic API:
#     ANTHROPIC_API_KEY=sk-ant-...
#   Option B — LLM Foundry proxy (llmfoundry.straivedemo.com):
#     ANTHROPIC_BASE_URL=https://llmfoundry.straivedemo.com/anthropic
#     ANTHROPIC_AUTH_TOKEN=<your-llmfoundry-token>
#
# These can also be configured through the web UI (Settings → Configure Claude).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=

OPENAI_API_KEY=
GEMINI_API_KEY=
GITHUB_TOKEN=

# LLM Foundry token — forwarded to ALL agent sessions.
# Required for the built-in OCR tool (Azure Form Recognizer via LLM Foundry).
# Get your token from https://llmfoundry.straive.com
LLMFOUNDRY_TOKEN=
