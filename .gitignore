# Dependencies
node_modules/
*/node_modules/
**/node_modules/
.pnpm-store/
.npm/

# Build output
dist/
build/
out/
*/dist/
*/build/
.vite/
.cache/
.turbo/

# TypeScript
*.tsbuildinfo

# Vite config build outputs (from tsc -b composite project)
client/vite.config.d.ts
client/vite.config.js

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage / test artifacts
coverage/
*.lcov
.nyc_output/

# Environment files (never commit secrets)
.env
.env.local
.env.*.local
.env.development
.env.production
*.env
!.env.example

# Editor / OS
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Per-project user data — created at runtime, must never be committed
projects/*
!projects/.gitkeep
data/*
!data/.gitkeep
sessions/

# Docker
.docker-tmp/

# Claude Code local state
.claude/

# Misc
*.tgz
*.tar.gz
